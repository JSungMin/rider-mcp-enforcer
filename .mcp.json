{
  "mcpServers": {
    "rider-search": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/proxy/src/server.js"],
      "env": {
        "RIDER_MCP_SSE_URL": "${RIDER_MCP_SSE_URL}",
        "RIDER_PROJECT_PATH": "${RIDER_PROJECT_PATH}",
        "RIDER_MAX_RESULTS": "50",
        "RIDER_ESCALATE_LIMIT": "500",
        "RIDER_MAX_LINE_CHARS": "200"
      }
    }
  }
}
